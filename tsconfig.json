{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "paths": {
      "openclaw/plugin-sdk/nostr": ["/usr/lib/node_modules/openclaw/dist/plugin-sdk/nostr.js"],
      "openclaw/plugin-sdk/compat": ["/usr/lib/node_modules/openclaw/dist/plugin-sdk/compat.js"],
      "openclaw/plugin-sdk/core": ["/usr/lib/node_modules/openclaw/dist/plugin-sdk/core.js"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
