{
  "name": "openclaw-max",
  "version": "0.1.0",
  "description": "MAX messenger channel plugin for OpenClaw",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --noEmit && echo 'TypeScript check passed (jiti loads TS directly)'",
    "typecheck": "tsc --noEmit",
    "test:api": "node --input-type=module ./scripts/test-api.mjs"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "openclaw-max",
      "label": "MAX",
      "selectionLabel": "MAX (max.ru)",
      "docsPath": "/channels/max",
      "docsLabel": "max",
      "blurb": "MAX messenger channel (max.ru Bot API)."
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": false
    }
  }
}
